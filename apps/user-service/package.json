{
	"name": "@ordernary/user-service",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "wrangler dev --x-remote-bindings --config wrangler.dev.jsonc --port 4000 --inspector-port 4001",
		"deploy": "wrangler deploy --config wrangler.jsonc",
		"deploy:dev": "wrangler deploy --config wrangler.dev.jsonc",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push --config drizzle.config.ts",
		"db:push:dev": "drizzle-kit push --config drizzle.config.dev.ts"
	},
	"devDependencies": {
		"typescript": "^5.5.2"
	},
	"dependencies": {
		"@ordernary/jwt-service": "workspace:*",
		"@ordernary/server-utils": "workspace:*",
		"@types/jsonwebtoken": "^9.0.10",
		"drizzle-kit": "^0.31.4",
		"drizzle-orm": "^0.44.5",
		"drizzle-zod": "^0.8.3",
		"googleapis": "^159.0.0",
		"jose": "^6.1.0",
		"jsonwebtoken": "^9.0.2",
		"wrangler": "4.35.0",
		"zod": "^4.1.8"
	}
}
